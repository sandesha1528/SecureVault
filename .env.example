# ─── SecureVault Environment Configuration ────────────────────────────────────
# Copy this file to .env and fill in all values before starting.
# Never commit .env to source control.

# ── Core ──────────────────────────────────────────────────────────────────────
SECUREVAULT_ENV=production
SECUREVAULT_VERSION=1.0.0

# ── Admin ─────────────────────────────────────────────────────────────────────
# Password for the superadmin user created on first boot.
SECUREVAULT_ADMIN_PASSWORD=change-me-immediately-use-a-strong-password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be a random 64-byte hex string. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(64))"
SECUREVAULT_JWT_SECRET=replace-with-128-char-hex-string

# Access token lifetime in minutes (default: 15)
SECUREVAULT_ACCESS_TOKEN_TTL=15

# Refresh token lifetime in days (default: 7)
SECUREVAULT_REFRESH_TOKEN_TTL=7

# ── Vault / Crypto ─────────────────────────────────────────────────────────────
# The root token is the seed for master key derivation.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# WARNING: Losing this token means losing all encrypted secrets permanently.
SECUREVAULT_ROOT_TOKEN=replace-with-64-char-hex-string

# PBKDF2 iterations for master key derivation (minimum: 600000)
SECUREVAULT_KDF_ITERATIONS=600000

# ── Database ──────────────────────────────────────────────────────────────────
# Absolute path inside the container; mapped via Docker volume
SECUREVAULT_DB_PATH=/app/data/securevault.db

# ── SSH CA ────────────────────────────────────────────────────────────────────
# Directory where CA keys are stored (encrypted)
SECUREVAULT_CA_DIR=/app/ca

# Default SSH certificate validity in hours
SECUREVAULT_SSH_CERT_TTL_HOURS=8

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
SECUREVAULT_CORS_ORIGINS=https://localhost,https://yourdomain.com

# ── Logging ───────────────────────────────────────────────────────────────────
SECUREVAULT_LOG_LEVEL=INFO

# ── Rotation ──────────────────────────────────────────────────────────────────
# How often (seconds) the scheduler wakes up to check for due rotations
SECUREVAULT_ROTATION_POLL_INTERVAL=60
